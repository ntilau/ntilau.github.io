#!/usr/bin/env bash
set -euo pipefail

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

install_macos() {
  echo "Detected macOS"
  if ! has_cmd brew; then
    echo "Homebrew not found. Install it first: https://brew.sh"
    exit 1
  fi
  brew install make texlive biber
}

install_debian_like() {
  echo "Detected Debian/Ubuntu"
  sudo apt-get update
  sudo apt-get install -y make texlive texlive-latex-extra texlive-fonts-extra biber
}

install_arch() {
  echo "Detected Arch Linux"
  sudo pacman -Sy --needed --noconfirm make texlive-most biber
}

install_fedora_like() {
  echo "Detected Fedora/RHEL-like Linux"
  sudo dnf install -y make texlive-scheme-full biber
}

main() {
  local os
  os="$(uname -s)"

  case "$os" in
    Darwin)
      install_macos
      ;;
    Linux)
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}" in
          ubuntu|debian)
            install_debian_like
            ;;
          arch)
            install_arch
            ;;
          fedora|rhel|centos)
            install_fedora_like
            ;;
          *)
            echo "Linux distribution '${ID:-unknown}' is not handled automatically."
            echo "Install manually: make, texlive, and biber."
            exit 1
            ;;
        esac
      else
        echo "/etc/os-release not found. Install manually: make, texlive, and biber."
        exit 1
      fi
      ;;
    *)
      echo "Unsupported OS: $os"
      echo "Install manually: make, texlive, and biber."
      exit 1
      ;;
  esac

  echo "Dependencies installed successfully."
}

main "$@"

if [ -f app.tex ]; then touch app.tex; done

